# ============================================================
# Server
# ============================================================
# 'production' on VPS — enables secure cookies & trust proxy defaults
NODE_ENV=production
# Bind address. Use 0.0.0.0 inside Docker / behind nginx.
HOST=0.0.0.0
PORT=4000

# ============================================================
# Sessions / Security
# ============================================================
# REQUIRED in production — use a long random string (>=32 chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string

# Comma-separated list of allowed browser origins for CORS.
# Use "*" to allow any origin (not recommended with credentials).
# Leave empty to reflect the request origin (dev only).
# Example: ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=https://your-domain.com

# Set to 1 when running behind nginx / a reverse proxy so Express
# reads X-Forwarded-* correctly (needed for secure cookies + rate limits).
TRUST_PROXY=1

# ============================================================
# Cloudinary (media storage)
# ============================================================
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_CLOUD_NAME=your_cloud_name

# ============================================================
# Redis (Upstash or self-hosted)
# ============================================================
REDIS_URL=rediss://default:your_redis_password@your-host.upstash.io:6379

# ============================================================
# Resend (email)
# ============================================================
RESEND_API_KEY=re_your_resend_api_key

# ============================================================
# Azure Speech Service (STT/TTS)
# ============================================================
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=southeastasia
AZURE_AVATAR_ENDPOINT=https://southeastasia.api.cognitive.microsoft.com/

# ============================================================
# Google Gemini (AI chat)
# ============================================================
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# ============================================================
# Avatar API
# ============================================================
AVATAR_SECRET_KEY=your_avatar_secret_key
