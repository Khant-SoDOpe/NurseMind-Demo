# ============================================================
# Server
# ============================================================
# 'production' on VPS — enables secure cookies & trust proxy defaults
NODE_ENV=production
# Bind address. Use 0.0.0.0 inside Docker / behind nginx.
HOST=0.0.0.0
PORT=4000

# ============================================================
# Sessions / Security
# ============================================================
# REQUIRED in production — use a long random string (>=32 chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string

# Comma-separated list of allowed browser origins for CORS.
# Use "*" to allow any origin (not recommended with credentials).
# Leave empty to reflect the request origin (dev only).
# Example: ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=https://your-domain.com

# Set to 1 when running behind nginx / a reverse proxy so Express
# reads X-Forwarded-* correctly (needed for secure cookies + rate limits).
TRUST_PROXY=1

# ============================================================
# Cloudinary (media storage)
# ============================================================
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_CLOUD_NAME=your_cloud_name

# ============================================================
# Redis (Upstash or self-hosted)
# ============================================================
REDIS_URL=rediss://default:your_redis_password@your-host.upstash.io:6379

# ============================================================
# Resend (email)
# ============================================================
RESEND_API_KEY=re_your_resend_api_key

# ============================================================
# Azure Speech Service (STT/TTS)
# ============================================================
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=southeastasia
AZURE_AVATAR_ENDPOINT=https://southeastasia.api.cognitive.microsoft.com/

# ============================================================
# AI Provider selection
# ============================================================
# Which LLM backend to use for /api/voice-chat and /api/ai-grade-assessment.
# Options: "gemini" | "openai"
# If unset, defaults to "openai" when OPENAI_API_KEY is set, otherwise "gemini".
AI_PROVIDER=gemini

# ---- Google Gemini ----
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# ---- OpenAI / ChatGPT ----
# Get a key: https://platform.openai.com/api-keys
# Cheap default: gpt-4o-mini.  Quality default: gpt-4o or gpt-4.1.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: override for OpenAI-compatible gateways (Azure OpenAI proxy,
# OpenRouter, Groq, local vLLM/Ollama, etc.). Leave empty for api.openai.com.
OPENAI_BASE_URL=

# ---- AI Grading overrides (used only by /api/ai-grade-assessment) ----
# Lets grading use a different backend than voice chat. Defaults to "openai"
# when OPENAI_API_KEY is set (more reliable JSON), otherwise AI_PROVIDER.
# AI_GRADING_PROVIDER=openai
# AI_GRADING_MODEL=gpt-4o-mini
# Max parallel students graded at once (1-8). Higher = faster, more API pressure.
# AI_GRADING_CONCURRENCY=5

# ============================================================
# Avatar / Assessment Video Generation
# ============================================================
# Which backend to use for POST /api/avatar/generate:
#   auto     - try Azure Batch Avatar Synthesis first, fall back to mooncalf (recommended)
#   azure    - Azure only (fails if Azure is misconfigured)
#   mooncalf - use the legacy team-mooncalf service only
AVATAR_PROVIDER=auto

# How often to poll Azure job status (ms) and when to give up (ms).
AVATAR_SYNTHESIS_POLL_MS=3000
AVATAR_SYNTHESIS_TIMEOUT_MS=300000

# Legacy mooncalf proxy (used as fallback). Leave blank if not in use.
AVATAR_SECRET_KEY=your_avatar_secret_key
